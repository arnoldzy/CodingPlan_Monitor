# 刷新间隔（秒）
MONITOR_REFRESH_INTERVAL=60

# GLM API Key (智谱AI)
GLM_API_KEY=your_glm_api_key_here

# MiniMax API Key
MINIMAX_API_KEY=your_minimax_api_key_here

# KIMI API KEY
KIMI_API_KEY=your_kimi_api_key_here

# GLM Model Usage 时间范围配置
# "5h" 表示获取过去5小时的使用量 (默认)
# "day" 表示获取当天的使用量 (00:00:00 - 23:59:59)
# "24h" 表示获取过去24小时的使用量 (当前时间 - 24小时)
GLM_USAGE_TIME_RANGE=5h
